# ============================================================
# PhaseGuard - Layer 2 Environment Configuration
#
# HACKATHON SETUP: This points at a SHARED Neon cloud PostgreSQL
# database (with pgvector enabled) so every teammate sees the same
# enrolled voiceprints without installing PostgreSQL locally.
#
# Replace the placeholder values below with the real connection
# string from whoever set up the Neon project, then copy this file
# to ".env" (do not commit your real .env).
# ============================================================

# --- Application ---
APP_NAME=PhaseGuard-Layer2
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database (Neon cloud PostgreSQL + pgvector) ---
# Get this connection string from your team's Neon dashboard.
# IMPORTANT: asyncpg uses "ssl=require", psycopg2 uses "sslmode=require"
# (different parameter names for the same thing — this is correct, not a typo)
DATABASE_URL=postgresql+asyncpg://neondb_owner:****************@ep-rough-queen-atcmnqdt-pooler.c-9.us-east-1.aws.neon.tech/neondb?ssl=require
DATABASE_URL_SYNC=postgresql+psycopg2://neondb_owner:****************@ep-rough-queen-atcmnqdt-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- ML / SpeechBrain ---
ECAPA_MODEL_SOURCE=speechbrain/spkrec-ecapa-voxceleb
ECAPA_MODEL_SAVE_DIR=./pretrained_models/ecapa
EMBEDDING_DIM=192
TARGET_SAMPLE_RATE=16000

# --- Verification ---
SIMILARITY_THRESHOLD=0.65
MIN_ENROLLMENT_RECORDINGS=3

# --- Risk Engine ---
LAYER1_FRAUD_THRESHOLD=0.70

# --- File handling ---
TEMP_UPLOAD_DIR=./data/temp_uploads
MAX_UPLOAD_SIZE_MB=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
